{
  "expo": {
    "name": "PICKS Folio",
    "slug": "picksfolio-mobile",
    "scheme": "picksfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0B0B0F",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.picksfolio.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "라이브 방송과 프로필·포트폴리오 사진 촬영에 카메라를 사용합니다.",
        "NSMicrophoneUsageDescription": "라이브 방송 진행 시 마이크를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "포트폴리오와 프로필 이미지를 업로드하기 위해 사진 보관함에 접근합니다.",
        "NSPhotoLibraryAddUsageDescription": "이미지를 저장하기 위해 사진 보관함에 접근합니다.",
        "LSApplicationQueriesSchemes": [
          "kakaokompassauth",
          "kakaolink",
          "kakaotalk",
          "kakaoplus",
          "storylink",
          "payco",
          "supertoss",
          "tossapp",
          "ispmobile",
          "kftc-bankpay",
          "kb-acp",
          "kbbank",
          "newliiv",
          "liivbank",
          "shinhan-sr-ansimclick",
          "smshinhanansimclick",
          "shinhan-sr-ansimclick-naverpay",
          "hdcardappcardansimclick",
          "lottesmartpay",
          "lotteappcard",
          "mpocket.online.ansimclick",
          "ansimclickscard",
          "samsungpay",
          "nhappvardansimclick",
          "nhallonepayansimclick",
          "citimobileapp",
          "lpayapp",
          "wooripay",
          "com.wooricard.wcard",
          "naversearchapp",
          "naverpaylink"
        ]
      }
    },
    "android": {
      "package": "com.picksfolio.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "./plugins/withoutIosPushEntitlement",
      [
        "expo-notifications",
        {
          "color": "#0B0B0F"
        }
      ],
      "./plugins/withDisableBitcode"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
